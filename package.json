{
  "name": "crowdtell",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A news feed driven by prediction markets. Reads Polymarket + Kalshi as a signal of what matters, then briefs you with grounded, cross-source reporting. 100% free, static, GitHub-native.",
  "homepage": "https://crowdtells.com/",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Samuel Jo (@squireaintready)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "tsx scripts/prerender-home.ts",
    "preview": "vite preview",
    "generate": "tsx --env-file-if-exists=.env scripts/generate.ts",
    "generate:dry": "tsx --env-file-if-exists=.env scripts/generate.ts --dry-run",
    "sync": "tsx --env-file-if-exists=.env scripts/sync-feed.ts",
    "digest": "tsx --env-file-if-exists=.env scripts/send-digest.ts",
    "digest:dry": "tsx --env-file-if-exists=.env scripts/send-digest.ts --dry-run",
    "confirm": "tsx --env-file-if-exists=.env scripts/send-confirmations.ts",
    "confirm:dry": "tsx --env-file-if-exists=.env scripts/send-confirmations.ts --dry-run",
    "breaking": "tsx --env-file-if-exists=.env scripts/send-breaking.ts",
    "breaking:dry": "tsx --env-file-if-exists=.env scripts/send-breaking.ts --dry-run",
    "social": "tsx --env-file-if-exists=.env scripts/send-social.ts",
    "social:dry": "tsx --env-file-if-exists=.env scripts/send-social.ts --dry-run",
    "replies": "tsx --env-file-if-exists=.env scripts/send-replies.ts",
    "replies:dry": "tsx --env-file-if-exists=.env scripts/send-replies.ts --dry-run",
    "user:export": "tsx --env-file-if-exists=.env scripts/export-user.ts",
    "user:delete": "tsx --env-file-if-exists=.env scripts/delete-user.ts",
    "admin:grant": "tsx --env-file-if-exists=.env scripts/grant-admin.ts",
    "seed": "tsx --env-file-if-exists=.env scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.108.2",
    "posthog-js": "^1.393.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.7",
    "vitest": "^3.2.0"
  }
}
